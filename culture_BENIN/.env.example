# Client access token for MapillaryJS (visites immersives 360°).
# Gratuit : créer un compte sur https://www.mapillary.com, puis une "app" sur
# https://www.mapillary.com/dashboard/developers pour obtenir un "Client Token".
VITE_MAPILLARY_ACCESS_TOKEN=

# URL de base de l'API backend CulturePlus Bénin (NestJS).
VITE_API_BASE_URL=https://cultureplusbenin-backend-nestjs.onrender.com
